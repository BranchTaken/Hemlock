# Tokenize `s`, e.g. "2 + 3 * 4", and append an `EOI` token.
tokenize s =
    s |> String.split_rev ~f:(fn cp -> Codepoint.O.(cp = ' '))
      |> List.rev_filter ~f:(fn s -> String.length s <> 0)
